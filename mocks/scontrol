#!/usr/bin/env bash

# Mock scontrol script for testing SLURM commands

# Optional: Add small delay to simulate real command execution
# sleep 0.1

# Get the directory where this script is located (same as mocks directory)
MOCKS_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Check if arguments match "show node[s] --json"
if [[ "$1" == "show" ]] && [[ "$2" =~ ^nodes?$ ]] && [[ "$3" == "--json" ]]; then
    if [ -f "$MOCKS_DIR/data/nodes.json" ]; then
        cat "$MOCKS_DIR/data/nodes.json"
    else
        echo "Error: nodes.json file not found in $MOCKS_DIR/data" >&2
        exit 1
    fi
elif [[ "$1" == "show" ]] && [[ "$2" =~ ^nodes?$ ]]; then
    if [ -f "$MOCKS_DIR/data/nodes" ]; then
        cat "$MOCKS_DIR/data/nodes"
    else
        echo "Error: nodes file not found in $MOCKS_DIR/data" >&2
        exit 1
    fi
elif [ "$1" = "show" ] && [ "$2" = "partitions" ] && [ "$3" = "--json" ]; then
    if [ -f "$MOCKS_DIR/data/partitions.json" ]; then
        cat "$MOCKS_DIR/data/partitions.json"
    else
        echo "Error: partitions.json file not found in $MOCKS_DIR/data" >&2
        exit 1
    fi
elif [ "$1" = "show" ] && [ "$2" = "partition" ] && [ -n "$3" ] && [ "$4" = "--json" ]; then
    # Show specific partition - filter from partitions.json
    PARTITION_NAME="$3"
    if [ -f "$MOCKS_DIR/data/partitions.json" ]; then
        python3 -c "
import json
data = json.load(open('$MOCKS_DIR/data/partitions.json'))
for p in data.get('partitions', []):
    if p.get('name') == '$PARTITION_NAME':
        nodes = p.get('nodes', {}).get('configured', '')
        print(json.dumps({'partitions': [{'name': '$PARTITION_NAME', 'nodes': {'nodes': nodes}}]}))
        exit()
print(json.dumps({'partitions': []}))
" 2>/dev/null || echo '{"partitions": []}'
    else
        echo '{"partitions": []}'
    fi
elif [ "$1" = "show" ] && [ "$2" = "partitions" ]; then
    if [ -f "$MOCKS_DIR/data/partitions" ]; then
        cat "$MOCKS_DIR/data/partitions"
    else
        echo "Error: partitions file not found in $MOCKS_DIR/data" >&2
        exit 1
    fi
elif [ "$1" = "show" ] && [ "$2" = "reservations" ] && [ "$3" = "--json" ]; then
    if [ -f "$MOCKS_DIR/data/reservations.json" ]; then
        cat "$MOCKS_DIR/data/reservations.json"
    else
        echo "Error: reservations.json file not found in $MOCKS_DIR/data" >&2
        exit 1
    fi
elif [ "$1" = "show" ] && [ "$2" = "reservation" ] && [ -n "$3" ] && [ "$4" = "--json" ]; then
    # Show specific reservation - filter from reservations.json
    RES_NAME="$3"
    if [ -f "$MOCKS_DIR/data/reservations.json" ]; then
        python3 -c "
import json
data = json.load(open('$MOCKS_DIR/data/reservations.json'))
res = data.get('$RES_NAME', {})
if res:
    print(json.dumps({'reservations': [{'name': '$RES_NAME', 'node_list': res.get('Nodes', '')}]}))
else:
    print(json.dumps({'reservations': []}))
" 2>/dev/null || echo '{"reservations": []}'
    else
        echo '{"reservations": []}'
    fi
elif [ "$1" = "show" ] && [ "$2" = "reservations" ]; then
    if [ -f "$MOCKS_DIR/data/reservations" ]; then
        cat "$MOCKS_DIR/data/reservations"
    else
        echo "Error: reservations file not found in $MOCKS_DIR/data" >&2
        exit 1
    fi
elif [ "$1" = "show" ] && [ "$2" = "config" ]; then
    if [ -f "$MOCKS_DIR/data/slurm_config" ]; then
        cat "$MOCKS_DIR/data/slurm_config"
    else
        echo "Error: slurm_config file not found in $MOCKS_DIR/data" >&2
        exit 1
    fi
elif [ "$1" = "create" ]; then
    # Mock create command - just print what was received
    echo "MOCK: scontrol $*"
    exit 0
elif [ "$1" = "update" ]; then
    # Mock update command - just print what was received
    echo "MOCK: scontrol $*"
    exit 0
elif [ "$1" = "delete" ]; then
    # Mock delete command - just print what was received
    echo "MOCK: scontrol $*"
    exit 0
else
    # For other arguments, show usage or error
    echo "Usage: $0 show {nodes|partitions|reservations|config} [--json]" >&2
    echo "This is a mock scontrol script for testing purposes." >&2
    echo "Arguments received: $*" >&2
    exit 1
fi
